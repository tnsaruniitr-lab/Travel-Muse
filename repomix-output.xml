  App = HowToPlanGroupTrip;
} else if (pathname === "/blog/oahu-group-trip-itinerary") {
  App = OahuGroupTripItinerary;
} else {
  App = Home;
}

hydrateRoot(document.getElementById("root")!, <App />);
